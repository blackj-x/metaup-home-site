---
import Base from './Base.astro';

export interface Props {
  title: string;
  description: string;
  kicker: string;
  date: string;
  /** 用于面包屑与标题展示的短标题 */
  heading: string;
}

const { title, description, kicker, date, heading } = Astro.props;
const pageTitle = `${title} - MetaUp 游戏攻略站群`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      inLanguage: 'zh-CN',
      datePublished: date,
      dateModified: date,
      author: { '@type': 'Organization', name: 'MetaUp 游戏攻略站群' },
      publisher: { '@type': 'Organization', name: 'MetaUp 游戏攻略站群' },
      url: new URL(Astro.url.pathname, Astro.site).href,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: new URL('/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: '编辑精选', item: new URL('/articles', Astro.site).href },
        { '@type': 'ListItem', position: 3, name: heading },
      ],
    },
  ],
};
---
<Base title={pageTitle} description={description} active="articles" jsonLd={jsonLd}>
  <div class="wrap detail">
    <div class="crumb"><a href="/">首页</a> / <a href="/articles">编辑精选</a> / {heading}</div>
    <div class="art-kicker">{kicker} · {date}</div>
    <h1>{title}</h1>
    <article class="detail-layout-single">
      <slot />
    </article>
  </div>
</Base>

<style>
  .art-kicker{color:var(--accent);font-size:13px;font-weight:900;letter-spacing:.5px;margin:8px 0 6px}
  h1{font-size:34px;line-height:1.3;margin-bottom:18px}
  @media(max-width:920px){h1{font-size:26px}}
</style>
