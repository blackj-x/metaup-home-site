---
import Base from './Base.astro';
import { absoluteUrl } from '../lib/url';

export interface Props {
  title: string;
  description: string;
  kicker: string;
  date: string;
  /** 用于面包屑与标题展示的短标题 */
  heading: string;
  lang?: 'zh' | 'en';
}

const { title, description, kicker, date, heading, lang = 'zh' } = Astro.props;
const isEn = lang === 'en';
const pageTitle = isEn ? `${title} - MetaUp Game Guides` : `${title} - MetaUp 游戏攻略站群`;
const pageUrl = absoluteUrl(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Article',
      headline: title,
      description,
      inLanguage: isEn ? 'en' : 'zh-CN',
      datePublished: date,
      dateModified: date,
      author: { '@type': 'Organization', name: isEn ? 'MetaUp Game Guides' : 'MetaUp 游戏攻略站群' },
      publisher: {
        '@type': 'Organization',
        name: isEn ? 'MetaUp Game Guides' : 'MetaUp 游戏攻略站群',
        logo: {
          '@type': 'ImageObject',
          url: new URL('/og-default.png', Astro.site).href
        }
      },
      url: pageUrl,
      image: new URL('/og-default.png', Astro.site).href,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: isEn
        ? [
            { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteUrl('/en/', Astro.site) },
            { '@type': 'ListItem', position: 2, name: 'Editorials', item: absoluteUrl('/en/articles/', Astro.site) },
            { '@type': 'ListItem', position: 3, name: heading },
          ]
        : [
            { '@type': 'ListItem', position: 1, name: '首页', item: absoluteUrl('/', Astro.site) },
            { '@type': 'ListItem', position: 2, name: '编辑精选', item: absoluteUrl('/articles/', Astro.site) },
            { '@type': 'ListItem', position: 3, name: heading },
          ],
    },
  ],
};
---
<Base title={pageTitle} description={description} active="articles" lang={lang} jsonLd={jsonLd}>
  <div class="wrap detail">
    <div class="crumb">
      <a href={isEn ? '/en/' : '/'}>{isEn ? 'Home' : '首页'}</a> / 
      <a href={isEn ? '/en/articles/' : '/articles/'}>{isEn ? 'Editorials' : '编辑精选'}</a> / {heading}
    </div>
    <div class="art-kicker">{kicker} · {date}</div>
    <h1>{title}</h1>
    <article class="detail-layout-single">
      <slot />
    </article>
  </div>
</Base>

<style>
  .art-kicker{color:var(--accent);font-size:13px;font-weight:900;letter-spacing:.5px;margin:8px 0 6px}
  h1{font-size:34px;line-height:1.3;margin-bottom:18px}
  @media(max-width:920px){h1{font-size:26px}}
</style>
