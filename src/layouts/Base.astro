---
import '../styles/global.css';
import { SITE } from '../data/site';
import { articles as zhArticles } from '../data/articles';
import { articles as enArticles } from '../data/en/articles';
import { absoluteUrl } from '../lib/url';

export interface Props {
  title: string;
  description: string;
  /** 结构化数据 JSON-LD，可选 */
  jsonLd?: object;
  /** 当前导航高亮 */
  active?: string;
  /** 社交分享图，可覆盖默认 */
  ogImage?: string;
  /** Language: 'zh' for root Chinese, 'en' for /en/ English section */
  lang?: 'zh' | 'en';
}

const { title, description, jsonLd, active, ogImage, lang = 'zh' } = Astro.props;
// Canonical always trailing-slash (trailingSlash: 'always')
const canonical = absoluteUrl(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage ?? SITE.defaultOgImage, Astro.site).href;
const isHome =
  Astro.url.pathname === '/' ||
  Astro.url.pathname === '/en/' ||
  Astro.url.pathname === '/en';

const isEn = lang === 'en';

// hreflang alternates (for bilingual zh root + /en/)
const currentPath = Astro.url.pathname.replace(/\/$/, ''); // normalize for logic

let zhHref: string;
let enHref: string;
let shouldOutputCrossLang = true;

const isArticlePage = currentPath.includes('/articles/');

if (isArticlePage) {
  // Extract slug
  const slugMatch = currentPath.match(/\/articles\/([^\/]+)/);
  const slug = slugMatch ? slugMatch[1] : '';

  const currentList = isEn ? enArticles : zhArticles;
  const oppositeList = isEn ? zhArticles : enArticles;

  const thisArt = currentList.find(a => a.slug === slug);
  const altSlug = thisArt?.alternateSlug;

  const selfHref = absoluteUrl(currentPath || '/', Astro.site);

  if (altSlug) {
    const oppositeArt = oppositeList.find(a => a.slug === altSlug);
    if (oppositeArt) {
      if (isEn) {
        zhHref = absoluteUrl(`/articles/${altSlug}`, Astro.site);
        enHref = selfHref;
      } else {
        zhHref = selfHref;
        enHref = absoluteUrl(`/en/articles/${altSlug}`, Astro.site);
      }
    } else {
      shouldOutputCrossLang = false;
      zhHref = selfHref;
      enHref = selfHref;
    }
  } else {
    shouldOutputCrossLang = false;
    zhHref = selfHref;
    enHref = selfHref;
  }
} else {
  // Static pages that have 1:1 correspondence (home, lists, about, faq, resources, contact, privacy)
  if (isEn) {
    zhHref = absoluteUrl(currentPath.replace(/^\/en/, '') || '/', Astro.site);
    enHref = absoluteUrl(currentPath || '/en', Astro.site);
  } else {
    zhHref = absoluteUrl(currentPath || '/', Astro.site);
    enHref = absoluteUrl(currentPath === '' || currentPath === '/' ? '/en/' : `/en${currentPath}`, Astro.site);
  }
}

// 网站级结构化数据
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: absoluteUrl(isEn ? '/en/' : '/', Astro.site),
  inLanguage: isEn ? 'en' : 'zh-CN',
};

// Language-aware navigation — all paths trailing-slash (hash anchors keep #)
// Do not rename keys: AdSense review period needs stable nav labels + compliance reachability
const navLinks = isEn
  ? [
      { href: '/en/', label: 'Home', key: 'home' },
      { href: '/en/#sites', label: 'Game Guides', key: 'sites' },
      { href: '/en/articles/', label: 'Editorials', key: 'articles' },
      { href: '/en/resources/', label: 'Resources', key: 'resources' },
      { href: '/en/faq/', label: 'FAQ', key: 'faq' },
      { href: '/en/about/', label: 'About', key: 'about' },
    ]
  : [
      { href: '/', label: '首页', key: 'home' },
      { href: '/#sites', label: '攻略站群', key: 'sites' },
      { href: '/articles/', label: '编辑精选', key: 'articles' },
      { href: '/resources/', label: '实用资源', key: 'resources' },
      { href: '/faq/', label: '常见问题', key: 'faq' },
      { href: '/about/', label: '关于', key: 'about' },
    ];

// Footer links — Privacy / About / Contact always present (compliance)
const footerLinks = isEn
  ? [
      { href: '/en/about/', label: 'About' },
      { href: '/en/faq/', label: 'FAQ' },
      { href: '/en/privacy/', label: 'Privacy' },
      { href: '/en/contact/', label: 'Contact' },
      { href: '/en/articles/', label: 'Editorials' },
      { href: '/en/resources/', label: 'Resources' },
    ]
  : [
      { href: '/about/', label: '关于站群' },
      { href: '/faq/', label: '常见问题' },
      { href: '/privacy/', label: '隐私政策' },
      { href: '/contact/', label: '联系我们' },
      { href: '/articles/', label: '编辑精选' },
      { href: '/resources/', label: '实用资源' },
    ];

const footerNote = isEn
  ? 'MetaUp Game Guides • One dedicated station per game • Original data-driven guides, not affiliated with any game publisher'
  : 'MetaUp 游戏攻略站群 · 各游戏独立成站、同一套准确性与原创性标准 · 基于公开游戏数据独立改写，与各游戏官方无关';

const logoText = isEn ? 'MetaUp' : 'MetaUp';
const logoSub = isEn ? 'Game Guides' : '游戏攻略站群';
---
<!DOCTYPE html>
<html lang={isEn ? 'en' : 'zh-CN'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content={SITE.themeColor} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <!-- hreflang for bilingual (zh root + /en/) -->
  <link rel="alternate" hreflang={isEn ? 'en' : 'zh'} href={canonical} />
  {shouldOutputCrossLang && (
    <link rel="alternate" hreflang={isEn ? 'zh' : 'en'} href={isEn ? zhHref : enHref} />
  )}
  <link rel="alternate" hreflang="x-default" href={isEn ? zhHref : canonical} />
  <!-- Open Graph -->
  <meta property="og:type" content={isHome ? 'website' : 'article'} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:locale" content={isEn ? 'en_US' : SITE.locale} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  {SITE.googleSiteVerification && <meta name="google-site-verification" content={SITE.googleSiteVerification} />}
  {SITE.adsenseClient && <meta name="google-adsense-account" content={SITE.adsenseClient} />}
  {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />}
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  {SITE.adsenseClient && (
    <script
      is:inline
      async
      src={`https://pagead2.googleapis.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClient}`}
      crossorigin="anonymous"
    />
  )}
  {SITE.cfBeaconToken && (
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={`{"token": "${SITE.cfBeaconToken}"}`}
    />
  )}
</head>
<body>
  <header>
    <nav class="nav">
      <a href={isEn ? '/en/' : '/'} class="logo"><span class="mark">▲</span>{logoText}<span class="logo-sub">{logoSub}</span></a>
      <div class="nav-links">
        {navLinks.map((l) => (
          <a href={l.href} class={active === l.key ? 'on' : ''}>{l.label}</a>
        ))}
      </div>
      <div class="lang-switch">
        {isEn ? (
          <a href="/" hreflang="zh" rel="alternate">中文</a>
        ) : (
          <a href="/en/" hreflang="en" rel="alternate">EN</a>
        )}
      </div>
    </nav>
  </header>
  <style>
    .lang-switch {
      margin-left: auto;
      font-size: 12px;
      font-weight: 700;
    }
    .lang-switch a {
      color: var(--txt-dim);
      padding: 4px 10px;
      border: 1px solid var(--line);
      border-radius: 6px;
      text-decoration: none;
    }
    .lang-switch a:hover {
      color: var(--txt);
      border-color: var(--accent);
    }
    .nav { display: flex; align-items: center; }
    .nav-links { display: flex; gap: 18px; }
  </style>
  <slot />
  <footer>
    <nav class="foot-links">
      {footerLinks.map((l) => (
        <a href={l.href}>{l.label}</a>
      ))}
    </nav>
    <div class="foot-note">{footerNote}</div>
  </footer>
</body>
</html>
