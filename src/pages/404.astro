---
import Base from '../layouts/Base.astro';
---
<Base title="页面不存在 - MetaUp 游戏攻略站群" description="页面未找到">
  <div class="wrap" style="padding:80px 0;text-align:center">
    <div style="font-size:72px">🗺️</div>
    <h1 style="font-size:34px;margin:16px 0 8px">404 · 这条路线没标点位</h1>
    <p style="color:var(--txt-dim);margin-bottom:24px">你要找的页面不存在,可能已被移动或写错了地址。</p>
    <a href="/" style="color:var(--accent);border:1px solid var(--line);padding:10px 20px;border-radius:10px;display:inline-block">← 返回站群首页</a>
  </div>
</Base>
