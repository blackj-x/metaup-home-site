---
import Base from '../../../layouts/Base.astro';
import { articles } from '../../../data/en/articles';

const title = 'Editorials - MetaUp Game Guides';
const description =
  'Original English writing from the MetaUp team: how we research and verify game data, practical advice for spotting good guides, co-op communication fundamentals, and more. Content you won’t find on the individual game stations.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'CollectionPage',
      name: title,
      description,
      inLanguage: 'en',
      url: new URL('/en/articles/', Astro.site).href,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/en/', Astro.site).href },
        { '@type': 'ListItem', position: 2, name: 'Editorials' },
      ],
    },
  ],
};
---

<Base title={title} description={description} active="articles" lang="en" jsonLd={jsonLd}>
  <div class="wrap detail">
    <div class="crumb"><a href="/en/">Home</a> / Editorials</div>
    <h1>Editorials</h1>
    <p class="lead">
      These articles live only on the mother site. They cover how we work, player skills that apply across games, and practical ways to judge whether any guide is worth trusting — including cross-game trend observations. No filler. No SEO keyword stuffing. Latest additions: 2026 Co-op Horror Watchlist and AI Search methodology.
    </p>

    <ul class="art-grid">
      {articles.map((a) => (
        <li>
          <a href={`/en/articles/${a.slug}/`}>
            <span class="k">{a.kicker}</span>
            <h2>{a.title}</h2>
            <p>{a.excerpt}</p>
            <span class="meta">{a.date} · Original editorial</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
  .art-grid{list-style:none;display:grid;grid-template-columns:1fr;gap:16px;max-width:840px;margin-bottom:40px}
  .art-grid li a{display:block;background:var(--bg-card);border:1px solid var(--line);border-radius:16px;padding:22px;transition:.18s}
  .art-grid li a:hover{border-color:var(--txt-dim);transform:translateY(-3px)}
  .art-grid .k{display:inline-block;font-size:11px;font-weight:900;color:var(--brand);background:rgba(91,140,255,.14);padding:3px 10px;border-radius:6px;margin-bottom:10px}
  .art-grid h2{font-size:20px;line-height:1.4;margin-bottom:8px;color:var(--txt)}
  .art-grid p{font-size:14.5px;color:var(--txt-dim);line-height:1.7;margin-bottom:10px}
  .art-grid .meta{font-size:12.5px;color:var(--txt-dim)}
</style>
