---
import Base from '../../layouts/Base.astro';
import { sites, liveSites } from '../../data/sites';
import { articles } from '../../data/en/articles';

const title = 'MetaUp Game Guides - Original, Verified, High-Quality Game Strategy Hub';
const description =
  'MetaUp (metaup.pro) is an independent game guide station network. For each game we build a dedicated station with thoroughly researched, fact-checked, original Chinese and English guides — complete with hand-drawn SVG maps. Currently covering Goose Goose Duck and Lethal Company, with regular updates. Bilingual content at the root domain.';

const updates = [
  {
    date: '2026-07-10',
    site: 'MetaUp',
    text: 'Weekly rhythm: watching The Mound pre-launch window (July 15 planned). Added internal links from process editorials to Trend Watch; timeline shows latest 8 only.',
  },
  {
    date: '2026-07-07',
    site: 'MetaUp',
    text: 'Quick Trends scan on "co-op horror 2026" shows rising searches for R.E.P.O., FEEDERS and similar. Watchlist entry traction good; routine maintenance + observation updates.',
  },
  {
    date: '2026-07-04',
    site: 'MetaUp',
    text: '2026 Co-op Horror Watchlist and AI Search citable guides methodology are now live. Daily maintenance on updates and trend entries; monitoring feedback.',
  },
  {
    date: '2026-07-02',
    site: 'MetaUp',
    text: 'Added bilingual 2026 Co-op Horror Watchlist + AI Search citable guides methodology. Trend Watch entry now surfaced on home and resources.',
  },
  {
    date: '2026-06-25',
    site: 'MetaUp',
    text: 'Added 3 new original English editorials + new FAQ page. Mother site content and bilingual coverage continues to expand.',
  },
  {
    date: '2026-06-24',
    site: 'MetaUp',
    text: 'Added 6 original English editorials total + new /resources page. New pieces cover patch note reading, building lasting personal knowledge systems, and more.',
  },
  {
    date: '2026-06-22',
    site: 'MetaUp',
    text: 'Refined article titles, meta descriptions and internal linking for better discoverability.',
  },
  {
    date: '2026-06-17',
    site: 'Goose Duck Guide',
    text: 'Minor role detail updates and map annotation fixes based on community reports.',
  },
  {
    date: '2026-06-16',
    site: 'Lethal Company Guide',
    text: 'Lethal Company station completed: 33+ monsters, moon layouts, scrap values, terminal commands, weather, and version tracking — all verified through our fact-checking pipeline.',
  },
  {
    date: '2026-06-13',
    site: 'Lethal Company Guide',
    text: 'Updated several monster counters and added new player FAQ section based on feedback.',
  },
  {
    date: '2026-06-11',
    site: 'Lethal Company Guide',
    text: 'Added weather mechanics and several moon variant descriptions. Fixed multiple value errors reported by players.',
  },
  {
    date: '2026-06-06',
    site: 'Goose Duck Guide',
    text: 'Goose Goose Duck full role compendium + original SVG maps went live as the first production station using structured data → auto-generated pages.',
  },
  {
    date: '2026-05-29',
    site: 'MetaUp',
    text: 'Began mother site content planning. Decided on the “one dedicated station per game + original editorials” approach.',
  },
  {
    date: '2026-05-25',
    site: 'MetaUp',
    text: 'Initial bilingual structure planning and E-E-A-T editorial series outline.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  inLanguage: 'en',
  url: new URL('/en/', Astro.site).href,
  hasPart: liveSites.map((s) => ({ '@type': 'WebSite', name: s.name, url: s.url })),
};
---

<Base title={title} description={description} active="home" lang="en" jsonLd={jsonLd}>
  <div class="wrap">
    <section class="hero">
      <div class="hero-copy">
        <div class="kicker">Independent Game Guide Network • metaup.pro</div>
        <h1>Guides that are <span class="em">thick, accurate, and original</span></h1>
        <p class="sub">
          MetaUp is not another wiki mirror or content farm. For every game we create a dedicated station. We take complex roles, monsters, maps, and mechanics, research them thoroughly, verify every data point, rewrite in clear English (and Chinese), and draw our own SVG maps. So you can check one thing before a run and actually trust it. Home to editorials and ongoing trend observations.
        </p>
        <div class="hero-actions">
          <a class="primary-btn" href="#sites">Browse Game Stations ↓</a>
          <a class="ghost-btn" href="/en/articles/">Read our editorials</a>
          <a class="ghost-btn" href="/en/resources/">Practical resources</a>
        </div>
      </div>
      <aside class="hero-stats" aria-label="Network overview">
        <div class="stat-card">
          <div class="stat-row"><b>{liveSites.length}</b><span>Live dedicated stations</span></div>
          <div class="stat-row"><b>{articles.length}</b><span>Original English editorials</span></div>
          <div class="stat-row"><b>SVG</b><span>All maps hand-drawn by us</span></div>
          <div class="stat-tag">Every guide passes a real fact-checking process • Uncertain numbers are clearly labeled</div>
        </div>
      </aside>
    </section>

    <section class="sites" id="sites">
      <div class="section-head">
        <div>
          <h2>Our Game Guide Stations</h2>
          <p>One focused station per game. Click a card to enter.</p>
        </div>
      </div>
      <div class="site-grid">
        {sites.map((s) => {
          const blurb = s.blurbEn || s.blurb;
          const tagline = s.taglineEn || s.tagline;
          const hl = s.highlightsEn || s.highlights;
          return (
            <a
              class="site-card"
              href={s.url}
              style={`--accent:${s.accent}`}
              rel={s.status === 'live' ? 'noopener' : 'nofollow noopener'}
              target="_blank"
            >
              <div class="site-top">
                <div class="site-icon">{s.icon}</div>
                <span class={`status ${s.status}`}>{s.status === 'live' ? 'Live' : 'Building'}</span>
              </div>
              <h3>{s.name}</h3>
              <div class="site-game">{s.game} · {s.gameEn}</div>
              <p class="site-tag">{tagline}</p>
              <p class="site-blurb">{blurb}</p>
              <div class="site-hl">
                {hl.map((h) => <span>{h}</span>)}
              </div>
              <div class="site-enter">Enter {s.url.replace('https://', '')} →</div>
            </a>
          );
        })}
      </div>
    </section>

    <section class="grid-2">
      <div class="feed">
        <div class="section-head">
          <div>
            <h2>Network Updates</h2>
            <p>What we’ve shipped and improved recently.</p>
          </div>
        </div>
        <ul class="timeline">
          {updates.slice(0, 8).map((u) => (
            <li>
              <div class="tl-head"><span class="tl-date">{u.date}</span><span class="tl-site">{u.site}</span></div>
              <p>{u.text}</p>
            </li>
          ))}
        </ul>
      </div>

      <div class="editorial">
        <div class="section-head">
          <div>
            <h2>Editorials</h2>
            <p>Original writing only available here on the mother site. Also see <a href="/en/resources/">practical resources</a>.</p>
          </div>
          <a href="/en/articles/">All editorials →</a>
        </div>

        <div class="trend-entry">
          <a href="/en/articles/2026-coop-horror-watchlist/">
            <span class="art-kicker">Trend Watch · Updated 2026-07-10</span>
            <strong>2026 Co-op Horror Watchlist: Which Games Merit Dedicated Guide Stations</strong>
            <span class="art-ex">Cursed Companions, MIMESIS, The Mound + Lethal Company benchmark. Release status, mechanics depth, and station potential.</span>
          </a>
        </div>

        <ul class="art-list">
          {articles.map((a) => (
            <li>
              <a href={`/en/articles/${a.slug}/`}>
                <span class="art-kicker">{a.kicker}</span>
                <strong>{a.title}</strong>
                <span class="art-ex">{a.excerpt}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Base>

<style>
  .hero{padding:54px 0 36px;display:grid;grid-template-columns:minmax(0,1.25fr) minmax(300px,.75fr);gap:32px;align-items:center}
  .kicker{color:var(--accent);font-size:13px;font-weight:900;letter-spacing:1px}
  h1{font-size:52px;font-weight:900;line-height:1.1;margin-top:10px}
  h1 .em{background:linear-gradient(120deg,var(--brand),var(--brand-2) 55%,var(--accent));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent}
  .sub{color:var(--txt-dim);margin-top:14px;max-width:660px;font-size:16.5px}
  .hero-actions{display:flex;gap:12px;margin-top:24px;flex-wrap:wrap}
  .primary-btn,.ghost-btn{min-height:44px;padding:10px 18px;border-radius:8px;font-weight:900;display:inline-flex;align-items:center;justify-content:center}
  .primary-btn{background:var(--accent);color:#1a1407}
  .ghost-btn{border:1px solid var(--line);background:rgba(26,32,52,.72);color:var(--txt)}
  .hero-stats{display:flex}
  .stat-card{width:100%;background:linear-gradient(160deg,rgba(26,32,52,.95),rgba(15,19,32,.8));border:1px solid var(--line);border-radius:18px;padding:20px;box-shadow:0 24px 60px -34px rgba(91,140,255,.9);position:relative;overflow:hidden}
  .stat-card::before{content:"";position:absolute;inset:0 0 auto;height:5px;background:linear-gradient(90deg,var(--brand),var(--brand-2),var(--accent))}
  .stat-row{display:flex;align-items:baseline;gap:12px;padding:11px 0;border-bottom:1px solid var(--line)}
  .stat-row b{font-size:34px;color:var(--txt);min-width:78px}
  .stat-row span{color:var(--txt-dim);font-size:14px}
  .stat-tag{margin-top:14px;font-size:12.5px;color:var(--txt-dim);line-height:1.6}

  .sites{margin:18px 0 12px}
  .site-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(330px,1fr));gap:18px}
  .site-card{background:var(--bg-card);border:1px solid var(--line);border-radius:18px;padding:22px;display:flex;flex-direction:column;transition:.18s;position:relative;overflow:hidden}
  .site-card::before{content:"";position:absolute;inset:0 0 auto 0;height:4px;background:var(--accent);opacity:.9}
  .site-card:hover{transform:translateY(-5px);border-color:var(--txt-dim);box-shadow:0 18px 44px -14px color-mix(in srgb,var(--accent) 60%,transparent)}
  .site-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
  .site-icon{width:54px;height:54px;border-radius:14px;display:grid;place-items:center;font-size:30px;background:color-mix(in srgb,var(--accent) 16%,transparent)}
  .status{font-size:11px;font-weight:700;padding:4px 10px;border-radius:7px}
  .status.live{background:rgba(84,210,138,.16);color:var(--good)}
  .status.building{background:rgba(154,166,200,.16);color:var(--txt-dim)}
  .site-card h3{font-size:21px;font-weight:900}
  .site-game{font-size:12.5px;color:var(--txt-dim);margin:2px 0 10px}
  .site-tag{font-size:14px;color:var(--accent);font-weight:700;margin-bottom:10px}
  .site-blurb{font-size:14px;color:var(--txt-dim);line-height:1.72;margin-bottom:14px}
  .site-hl{display:flex;gap:7px;flex-wrap:wrap;margin-top:auto}
  .site-hl span{font-size:11.5px;color:var(--txt-dim);background:var(--bg-elev);border:1px solid var(--line);padding:4px 9px;border-radius:6px}
  .site-enter{margin-top:16px;font-size:13.5px;font-weight:900;color:var(--accent)}

  .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:44px}
  .timeline{list-style:none;display:flex;flex-direction:column;gap:12px}
  .timeline li{background:var(--bg-card);border:1px solid var(--line);border-radius:14px;padding:16px 18px}
  .tl-head{display:flex;gap:10px;align-items:center;margin-bottom:6px}
  .tl-date{font-size:12px;color:var(--txt-dim);font-variant-numeric:tabular-nums}
  .tl-site{font-size:12px;font-weight:700;color:var(--accent);background:rgba(255,203,69,.12);padding:2px 8px;border-radius:6px}
  .timeline p{font-size:14px;color:var(--txt-dim);line-height:1.7}

  .art-list{list-style:none;display:flex;flex-direction:column;gap:12px}
  .art-list li a{display:block;background:var(--bg-card);border:1px solid var(--line);border-radius:14px;padding:16px 18px;transition:.18s}
  .art-list li a:hover{border-color:var(--txt-dim);transform:translateY(-3px)}
  .art-kicker{display:inline-block;font-size:11px;font-weight:900;color:var(--brand);background:rgba(91,140,255,.14);padding:3px 9px;border-radius:6px;margin-bottom:8px}
  .art-list strong{display:block;font-size:16px;line-height:1.45;margin-bottom:6px}
  .art-ex{display:block;font-size:13.5px;color:var(--txt-dim);line-height:1.6}

  .trend-entry{margin-bottom:8px}
  .trend-entry a{display:block;background:linear-gradient(145deg,var(--bg-elev),var(--bg-card));border:1px solid var(--accent);border-radius:14px;padding:16px 18px;transition:.18s}
  .trend-entry a:hover{border-color:#ffdf8a;transform:translateY(-2px)}
  .trend-entry .art-kicker{background:rgba(255,203,69,.18);color:var(--accent)}
  .trend-entry strong{display:block;font-size:15.5px;line-height:1.4;margin:4px 0 4px;color:var(--txt)}
  .trend-entry .art-ex{font-size:13px;color:var(--txt-dim)}

  @media(max-width:980px){.hero{grid-template-columns:1fr}.grid-2{grid-template-columns:1fr}}
  @media(max-width:560px){h1{font-size:38px}.site-grid{grid-template-columns:1fr}}
</style>
